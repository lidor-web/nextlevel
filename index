<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Next Level USA | מלגות כדורגל בארה"ב</title>
<!-- Google Fonts: Assistant -->
<link href="https://fonts.googleapis.com/css2?family=Assistant:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
<style>
  :root {
    --navy: #00113a;
    --navy-light: #002366;
    --red: #bb001c;
    --red-dark: #930013;
    --gold: #e9c349;
    --gold-dark: #574500;
    --white: #ffffff;
    --off-white: #f8f9fa;
    --gray: #c5c6d2;
    --text-muted: rgba(255,255,255,0.6);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Assistant', sans-serif;
    background: var(--off-white);
    color: #191c1d;
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--navy); }
  ::-webkit-scrollbar-thumb { background: var(--red); border-radius: 3px; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    padding: 0 40px;
    background: rgba(0,17,58,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: all 0.3s;
  }
  .nav-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 80px;
  }
  .logo-container img {
    height: 60px; /* גובה הלוגו */
    width: auto;
    display: block;
    transition: transform 0.3s;
  }
  .logo-container img:hover {
    transform: scale(1.05);
  }
  
  .nav-links { display: flex; gap: 36px; align-items: center; }
  .nav-links a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 1rem; font-weight: 600;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-links a.active { color: var(--gold); }
  
  .btn-nav {
    background: var(--gold); color: var(--navy);
    border: none; cursor: pointer;
    padding: 10px 24px; border-radius: 4px;
    font-weight: 800;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: all 0.2s; box-shadow: 0 4px 0 var(--gold-dark);
    text-decoration: none;
  }
  .btn-nav:hover { transform: translateY(2px); box-shadow: 0 2px 0 var(--gold-dark); }

  /* ─── HERO ─── */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.3) saturate(1.1);
  }
  .hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,17,58,0.95) 0%, rgba(0,17,58,0.6) 50%, transparent 100%);
  }

  .hero-content {
    position: relative; z-index: 10;
    max-width: 1280px; margin: 0 auto;
    padding: 120px 60px 60px;
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 60px; align-items: center;
    width: 100%;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(187,0,28,0.15);
    border: 1px solid rgba(187,0,28,0.35);
    border-radius: 100px; padding: 8px 18px;
    margin-bottom: 28px;
  }
  .hero-badge span {
    color: #ff4d6a; font-size: 0.85rem;
    font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 800; line-height: 1.1;
    color: var(--white); margin-bottom: 24px;
  }
  .hero h1 .accent { color: var(--gold); }
  .hero p {
    font-size: 1.3rem; color: rgba(255,255,255,0.85);
    max-width: 650px; line-height: 1.6;
    margin-bottom: 40px; font-weight: 400;
  }
  .hero-ctas { display: flex; gap: 20px; flex-wrap: wrap; }
  
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--gold); color: var(--navy);
    border: none; cursor: pointer;
    padding: 18px 36px; border-radius: 8px;
    font-weight: 800;
    font-size: 1.1rem;
    box-shadow: 0 5px 0 var(--gold-dark);
    transition: all 0.2s; text-decoration: none;
  }
  .btn-primary:hover { transform: translateY(3px); box-shadow: 0 2px 0 var(--gold-dark); }
  
  .btn-secondary {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.2);
    color: var(--white); cursor: pointer;
    padding: 18px 36px; border-radius: 8px;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.2s; text-decoration: none;
    backdrop-filter: blur(10px);
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.2); }

  /* Hero Card - College Player Image */
  .hero-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    padding: 12px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.4);
    transform: perspective(1000px) rotateY(-5deg);
    transition: transform 0.6s ease;
  }
  .hero-card:hover { transform: perspective(1000px) rotateY(0deg); }
  .hero-card img { 
    width: 100%; border-radius: 12px; 
    aspect-ratio: 4/5; object-fit: cover; 
    display: block;
  }
  .hero-stats {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;
  }
  .stat { text-align: center; }
  .stat-num { font-size: 1.5rem; font-weight: 800; color: var(--gold); }
  .stat-label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }

  /* ─── BENTO GRID ─── */
  .bento-section {
    padding: 100px 60px;
    max-width: 1280px; margin: 0 auto;
  }
  .section-label {
    font-size: 0.9rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 12px; display: block;
    color: var(--red);
  }
  .bento-header { margin-bottom: 50px; }
  .bento-header h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800; color: var(--navy);
    line-height: 1.2;
  }
  
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
  }
  .bento-card {
    border-radius: 20px; padding: 40px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative; overflow: hidden;
  }
  .bento-card:hover { transform: translateY(-8px); box-shadow: 0 30px 60px rgba(0,17,58,0.15); }

  .bc-experience { grid-column: span 8; background: var(--navy); color: var(--white); }
  .bc-marketing { grid-column: span 4; background: var(--red); color: var(--white); }
  .bc-network { grid-column: span 4; background: #fff; border: 1px solid #ddd; }
  .bc-training { grid-column: span 8; background: #fff; border: 1px solid #ddd; }
  
  .bento-card h3 { font-size: 1.8rem; font-weight: 800; margin-bottom: 15px; }
  .bento-card p { font-size: 1.1rem; line-height: 1.6; opacity: 0.9; }
  .material-symbols-outlined { font-size: 3rem; margin-bottom: 20px; color: var(--gold); display: block; }

  /* ─── PROCESS ─── */
  .process-section {
    background: var(--navy);
    padding: 120px 60px;
    color: white;
    text-align: center;
  }
  .steps-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 30px; margin-top: 60px;
  }
  .step-number {
    font-size: 3rem; font-weight: 900; color: rgba(255,255,255,0.1);
    margin-bottom: -20px;
  }
  .step h4 { font-size: 1.3rem; margin-bottom: 10px; color: var(--gold); }

  /* ─── TESTIMONIALS ─── */
  .testimonials-section {
    padding: 120px 60px;
    background: #f0f2f5;
  }
  .testimonials-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;
    max-width: 1280px; margin: 50px auto 0;
  }
  .tcard {
    background: white; padding: 40px; border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-right: 5px solid var(--red);
  }
  .tcard-name { font-weight: 800; font-size: 1.2rem; color: var(--navy); }
  .tcard-school { color: var(--red); font-weight: 700; font-size: 0.9rem; margin-bottom: 15px; }
  .tcard blockquote { font-style: italic; color: #555; line-height: 1.7; }

  /* ─── FORM ─── */
  .form-section { padding: 100px 60px; background: white; }
  .form-container {
    max-width: 800px; margin: 0 auto;
    background: var(--off-white); padding: 50px;
    border-radius: 30px; border: 1px solid #eee;
  }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .full { grid-column: span 2; }
  input, select {
    padding: 15px; border-radius: 10px; border: 1px solid #ddd;
    font-family: 'Assistant', sans-serif; font-size: 1rem;
  }
  .btn-submit {
    background: var(--gold); color: var(--navy);
    border: none; padding: 20px; border-radius: 10px;
    font-weight: 800; font-size: 1.2rem; cursor: pointer;
    box-shadow: 0 6px 0 var(--gold-dark); transition: all 0.2s;
  }
  .btn-submit:hover { transform: translateY(3px); box-shadow: 0 3px 0 var(--gold-dark); }

  /* ─── FOOTER ─── */
  footer { background: #00081a; color: white; padding: 80px 60px 40px; }
  .footer-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; justify-content: space-between; align-items: flex-start;
    border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 40px;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .hero-content { grid-template-columns: 1fr; text-align: center; }
    .hero-ctas { justify-content: center; }
    .hero-card { display: none; }
    .bento-grid, .steps-grid, .testimonials-grid { grid-template-columns: 1fr; }
    .bc-experience, .bc-marketing, .bc-network, .bc-training { grid-column: span 1; }
    .nav-inner { padding: 0 20px; }
    .nav-links { display: none; }
  }

  .reveal { opacity: 0; transform: translateY(30px); transition: 0.8s all ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>
</head>
